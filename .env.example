# Firebase 웹앱 설정. ★ 베팅판(HK_Betting)과 같은 Firebase 프로젝트 값을 그대로 사용 ★
#   → 같은 projectId 를 써야 users/{id}.balance(포인트)가 두 앱에서 공유됩니다.
# 실제 값은 .env 로 복사해 채우고 커밋하지 않음.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 운영자 구글 로그인 허용 이메일(콤마 구분). 비우면 구글 로그인=누구나 운영자(로컬 테스트).
# ★ Cloud Functions 쪽 ADMIN_EMAILS 와 반드시 일치시킬 것 ★
VITE_ADMIN_EMAILS=

# (선택) Functions 리전. 기본 us-central1. 함수 배포 리전과 일치시킬 것.
VITE_FUNCTIONS_REGION=us-central1
